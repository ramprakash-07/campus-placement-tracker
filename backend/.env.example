# ============================================================
# Backend Environment Variables — copy to .env and fill in
# ============================================================

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/campus_placement_tracker

# Secret key for signing JWT tokens (generate a strong random value!)
SECRET_KEY=your-secret-key-here

# JWT signing algorithm (default: HS256)
ALGORITHM=HS256

# Access-token lifetime in minutes (default: 30)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Frontend URL for CORS (default: http://localhost:5173)
FRONTEND_URL=http://localhost:5173

# Secret invite code required to register as a coordinator (optional)
COORDINATOR_INVITE_CODE=your_secret_here
